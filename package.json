{
  "name": "@webmcp-registry/kit",
  "version": "0.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Define and register WebMCP tools with Zod schemas, React hooks, and a CLI that syncs them to the WebMCP Registry.",
  "keywords": [
    "webmcp",
    "mcp",
    "model-context-protocol",
    "ai",
    "agents",
    "tools",
    "react",
    "zod",
    "browser"
  ],
  "homepage": "https://github.com/WebMCP-Registry/kit#readme",
  "bugs": {
    "url": "https://github.com/WebMCP-Registry/kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebMCP-Registry/kit.git"
  },
  "license": "MIT",
  "author": "WebMCP Registry",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "webmcp": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=23.6.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "zod": "^3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  }
}
